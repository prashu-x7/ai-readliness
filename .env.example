# ── App Settings ──────────────────────────────────────────────────────────
APP_NAME=App Reader
DEBUG=false
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# ── Database (MongoDB) ────────────────────────────────────────────────────
# For Railway: use the Railway MongoDB plugin URL
# For MongoDB Atlas: use the Atlas connection string
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=appReader

# ── JWT Auth ──────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ── CORS (set to your Railway frontend URL in production) ─────────────────
# Example: CORS_ORIGINS=https://your-app.up.railway.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Groq LLM API ──────────────────────────────────────────────────────────
# Get your key from https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ── Frontend (set in Railway frontend service) ────────────────────────────
# VITE_API_URL=https://your-backend.up.railway.app/api
